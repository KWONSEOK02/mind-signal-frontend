NEXT_PUBLIC_NODE_ENV=local

# 백엔드 API 서버 주소 (예: https://api.your-domain.com/api)
NEXT_PUBLIC_API_URL=YOUR_BACKEND_API_URL_HERE

# 페어링 세션 유효 시간 (초 단위, 기본값 300)
NEXT_PUBLIC_PAIRING_TIMEOUT=300

# 실시간 데이터 스트리밍용 Socket.io 주소 (예: https://api.your-domain.com)
NEXT_PUBLIC_SOCKET_URL=YOUR_BACKEND_API_URL_HERE

# 소셜 로그인 — Google Cloud Console > OAuth 2.0 클라이언트 ID
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here

# 소셜 로그인 — Kakao Developers > 내 애플리케이션 > 앱 키 > REST API 키
NEXT_PUBLIC_KAKAO_CLIENT_ID=your_kakao_rest_api_key_here

# 소셜 로그인 — Kakao Developers > 내 애플리케이션 > 앱 키 > JavaScript 키
NEXT_PUBLIC_KAKAO_JS_KEY=your_kakao_javascript_key_here
